FROM oven/bun:1

RUN apt-get update -qq && apt-get install -y -qq git bzip2 postgresql-client && rm -rf /var/lib/apt/lists/*

WORKDIR /app
RUN git clone https://github.com/Clevermation/firmen-intelligence.git /app
RUN bun install

COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3000
ENTRYPOINT ["/entrypoint.sh"]
